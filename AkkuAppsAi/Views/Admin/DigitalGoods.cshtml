@model List<AkkuAppsAi.Models.DigitalGood>
@{ ViewData["Title"] = "Digital Goods"; }

<div class="page-container">
    <div class="page-header">
        <div>
            <h1><i class="fas fa-cube"></i> Digital Goods</h1>
            <p>Manage all digital products in the marketplace</p>
        </div>
        <button class="btn btn-primary" onclick="document.getElementById('createForm').style.display='block'">
            <i class="fas fa-plus"></i> Create Good
        </button>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success"><i class="fas fa-check"></i> @TempData["Success"]</div> }

    <div class="card mb-3" id="createForm" style="display:none;">
        <div class="card-header flex justify-between items-center">
            <h3 style="margin:0;font-size:1rem;">Create New Digital Good</h3>
            <button class="btn btn-sm btn-ghost" onclick="document.getElementById('createForm').style.display='none'"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-body">
            <form method="post" asp-action="CreateDigitalGood">
                <div class="grid-2">
                    <div class="form-group">
                        <label>Title *</label>
                        <input type="text" name="title" class="form-input" required />
                    </div>
                    <div class="form-group">
                        <label>Category</label>
                        <input type="text" name="category" class="form-input" placeholder="e.g., Templates" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" class="form-input" rows="2"></textarea>
                </div>
                <div class="grid-2">
                    <div class="form-group">
                        <label>Price (Coins) *</label>
                        <input type="number" name="priceInCoins" class="form-input" step="1" min="1" required />
                    </div>
                    <div class="form-group" style="display:flex;align-items:flex-end;">
                        <label class="flex items-center gap-1" style="cursor:pointer;">
                            <input type="checkbox" name="hasCommission" value="true" style="width:18px;height:18px;accent-color:var(--acc);" />
                            <span>Apply 10% Commission</span>
                        </label>
                    </div>
                </div>
                <div class="grid-2">
                    <div class="form-group">
                        <label>Thumbnail URL</label>
                        <input type="url" name="thumbnailUrl" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>File URL</label>
                        <input type="url" name="fileUrl" class="form-input" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success"><i class="fas fa-upload"></i> Create</button>
            </form>
        </div>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>Title</th><th>Category</th><th>Price</th><th>Commission</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var g in Model)
                {
                    <tr>
                        <td style="font-weight:500;">@g.Title</td>
                        <td><span class="badge badge-primary">@g.Category</span></td>
                        <td class="coin-amount">@g.PriceInCoins.ToString("N0")</td>
                        <td>@(g.HasCommission ? "10%" : "-")</td>
                        <td><span class="badge @(g.IsActive ? "badge-success" : "badge-danger")">@(g.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            @{ var btnClass = g.IsActive ? "btn-danger" : "btn-success"; var btnText = g.IsActive ? "Deactivate" : "Activate"; }
                            <form method="post" asp-action="ToggleGood" style="display:inline;">
                                <input type="hidden" name="goodId" value="@g.GoodId" />
                                <input type="hidden" name="isActive" value="@(g.IsActive ? "false" : "true")" />
                                <button type="submit" class="btn btn-sm @btnClass">@btnText</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
