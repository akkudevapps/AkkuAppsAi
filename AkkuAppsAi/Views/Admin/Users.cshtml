@model List<AkkuAppsAi.Models.User>
@{ ViewData["Title"] = "User Management"; }

<div class="page-container">
    <div class="page-header">
        <div>
            <h1><i class="fas fa-users-cog"></i> User Management</h1>
            <p>Manage all users, roles, and promotions</p>
        </div>
        <form method="get" class="flex gap-1">
            <input type="text" name="search" class="form-input" style="width:200px;" placeholder="Search..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        </form>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success"><i class="fas fa-check"></i> @TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger"><i class="fas fa-times"></i> @TempData["Error"]</div> }

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Type</th>
                    <th>Coins</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td><a href="/Admin/UserDetail/@u.UserId" style="color:var(--acc);text-decoration:none;font-weight:500;">@u.Name</a></td>
                        <td style="color:var(--txt2);font-size:0.8rem;">@u.Email</td>
                        <td>
                            <span class="badge @(u.UserType == "AkkuAdmin" ? "badge-danger" : u.UserType == "AkkuProUser" ? "badge-purple" : "badge-primary")">@u.UserType</span>
                        </td>
                        <td class="coin-amount">@u.CoinBalance.ToString("N0")</td>
                        <td>
                            @if (u.IsBanned) { <span class="badge badge-danger">Banned</span> }
                            else { <span class="badge badge-success">Active</span> }
                        </td>
                        <td>
                            <div class="flex gap-1">
                                <a href="/Admin/UserDetail/@u.UserId" class="btn btn-sm btn-ghost" data-tooltip="View"><i class="fas fa-eye"></i></a>
                                <form method="post" asp-action="ToggleBan">
                                    <input type="hidden" name="userId" value="@u.UserId" />
                                    <input type="hidden" name="isBanned" value="@(u.IsBanned ? "false" : "true")" />
                                    <button type="submit" class="btn btn-sm @(u.IsBanned ? "btn-success" : "btn-danger")" data-tooltip="@(u.IsBanned ? "Unban" : "Ban")">
                                        <i class="fas @(u.IsBanned ? "fa-check" : "fa-ban")"></i>
                                    </button>
                                </form>
                                @if (u.UserType != "AkkuAdmin")
                                {
                                    <button class="btn btn-sm btn-warning" onclick="promote('@u.UserId','@u.Name')" data-tooltip="Promote"><i class="fas fa-arrow-up"></i></button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="promoteModal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <h3>Promote User</h3>
        <p id="promoteUserInfo" style="color:var(--txt2);"></p>
        <form method="post" asp-action="PromoteUser">
            <input type="hidden" name="userId" id="promoteUserId" />
            <div class="form-group">
                <label>Plan Name</label>
                <select name="planName" class="form-input" required>
                    <option value="Silver">Silver Plan - 500 Coins</option>
                    <option value="Gold">Gold Plan - 1,000 Coins</option>
                    <option value="Diamond">Diamond Plan - 2,000 Coins</option>
                </select>
            </div>
            <div class="form-group">
                <label>Coins to Charge</label>
                <input type="number" name="coinsCharged" class="form-input" value="500" step="1" required />
            </div>
            <div class="flex gap-1 justify-between mt-2">
                <button type="button" class="btn btn-ghost" onclick="document.getElementById('promoteModal').style.display='none'">Cancel</button>
                <button type="submit" class="btn btn-primary">Promote</button>
            </div>
        </form>
    </div>
</div>

<style>
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-box { background: var(--panel); border: 1px solid var(--bdr); border-radius: var(--radius-lg); padding: 2rem; width: 400px; max-width: 90vw; animation: scaleIn 0.3s ease; }
    .modal-box h3 { margin: 0 0 0.5rem; }
</style>

<script>
    function promote(userId, name) {
        document.getElementById('promoteUserId').value = userId;
        document.getElementById('promoteUserInfo').textContent = 'Promote ' + name;
        document.getElementById('promoteModal').style.display = 'flex';
    }
</script>
