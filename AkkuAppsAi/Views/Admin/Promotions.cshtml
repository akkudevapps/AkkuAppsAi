@model List<AkkuAppsAi.Models.UserPromotion>
@{ ViewData["Title"] = "Promotions"; }

<div class="page-container">
    <div class="page-header">
        <div>
            <h1><i class="fas fa-arrow-up"></i> User Promotions</h1>
            <p>Track all user promotion history</p>
        </div>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>User ID</th><th>New Type</th><th>Plan</th><th>Coins Charged</th><th>Approved By</th><th>Date</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:0.8rem;">@p.UserId[..8]</code></td>
                        <td><span class="badge badge-purple">@p.NewUserType</span></td>
                        <td>@p.PlanName</td>
                        <td class="coin-amount">@p.CoinsCharged.ToString("N0")</td>
                        <td>@p.ApprovedBy?[..8]...</td>
                        <td>@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
