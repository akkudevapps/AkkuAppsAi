
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#09090f" />
    <title>@ViewData["Title"] - AkkuAppsAi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="akku-navbar">
        <div class="nav-container">
            <div class="nav-left">
                <button class="hamburger" id="left-menu-toggle" data-sidebar-toggle aria-label="Open menu">
                    <i class="fas fa-bars"></i>
                </button>
                <a href="/" class="brand">
                    <i class="fas fa-robot"></i> AkkuAppsAi
                </a>
            </div>
            <div class="nav-center">
                <a href="/" class="nav-btn"><i class="fas fa-home"></i> <span>Home</span></a>
                <a href="/Marketplace" class="nav-btn"><i class="fas fa-store"></i> <span>Market</span></a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Dashboard" class="nav-btn"><i class="fas fa-th-large"></i> <span>Dashboard</span></a>
                    <a href="/Chat" class="nav-btn"><i class="fas fa-comment-dots"></i> <span>Chat</span></a>
                }
            </div>
            <div class="nav-right">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Coins/Buy" class="nav-btn nav-btn-highlight"><i class="fas fa-coins"></i></a>
                    <button class="nav-btn" id="right-menu-toggle" data-right-sidebar-toggle aria-label="Open info panel">
                        <i class="fas fa-bell"></i>
                        <span class="notification-dot"></span>
                    </button>
                    <a href="/Profile" class="nav-btn nav-btn-avatar">
                        @{
                            var avatar = User.FindFirst("picture")?.Value;
                            var name = User.Identity.Name ?? "U";
                        }
                        @if (!string.IsNullOrEmpty(avatar))
                        {
                            <img src="@avatar" alt="@name" />
                        }
                        else
                        {
                            <span class="avatar-initial">@name[0]</span>
                        }
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="nav-btn" title="Logout" style="border:none;background:none;cursor:pointer;color:var(--txt);">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="nav-btn nav-btn-primary">
                        <i class="fas fa-sign-in-alt"></i> <span>Login</span>
                    </a>
                }
                <button class="hamburger" id="mobile-menu-toggle" aria-label="Mobile menu">
                    <i class="fas fa-ellipsis-v"></i>
                </button>
            </div>
        </div>
    </nav>

    <!-- Left Sidebar -->
    <aside id="left-sidebar" class="sidebar sidebar-left">
        <div class="sidebar-header">
            <a href="/" class="sidebar-brand">
                <i class="fas fa-robot"></i> AkkuAppsAi
            </a>
            <button class="sidebar-close" id="left-sidebar-close">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="sidebar-content">
            <nav class="sidebar-nav">
                <a href="/" class="sidebar-link"><i class="fas fa-home"></i> Home</a>
                <a href="/Marketplace" class="sidebar-link"><i class="fas fa-store"></i> Marketplace</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="sidebar-section">
                        <span class="sidebar-section-title">Main</span>
                        <a href="/Dashboard" class="sidebar-link"><i class="fas fa-th-large"></i> Dashboard</a>
                        <a href="/Profile" class="sidebar-link"><i class="fas fa-user"></i> My Profile</a>
                        <a href="/Coins/Buy" class="sidebar-link"><i class="fas fa-coins"></i> Buy Coins</a>
                        <a href="/Coins/MyOrders" class="sidebar-link"><i class="fas fa-receipt"></i> My Orders</a>
                    </div>
                    <div class="sidebar-section">
                        <span class="sidebar-section-title">Tools</span>
                        <a href="/Chat" class="sidebar-link"><i class="fas fa-robot"></i> AI Chat</a>
                        <a href="/Tools/ImageEditor" class="sidebar-link"><i class="fas fa-palette"></i> Image Editor</a>
                        <a href="/Tools/JsonCreator" class="sidebar-link"><i class="fas fa-code"></i> JSON Creator</a>
                        <a href="/Tools/OCR" class="sidebar-link"><i class="fas fa-file-alt"></i> OCR Scanner</a>
                        <a href="/Tools/PDFReader" class="sidebar-link"><i class="fas fa-file-pdf"></i> PDF Reader</a>
                    </div>
                    <div class="sidebar-section">
                        <span class="sidebar-section-title">Marketplace</span>
                        <a href="/Marketplace" class="sidebar-link"><i class="fas fa-store"></i> Browse Goods</a>
                        <a href="/Marketplace/MyPurchases" class="sidebar-link"><i class="fas fa-shopping-bag"></i> My Purchases</a>
                        @if (User.IsInRole("admin") || User.IsInRole("pro"))
                        {
                            <a href="/Marketplace/MyGoods" class="sidebar-link"><i class="fas fa-cubes"></i> My Goods</a>
                            <a href="/Marketplace/Create" class="sidebar-link"><i class="fas fa-plus"></i> Create Good</a>
                        }
                    </div>
                    @if (User.IsInRole("admin"))
                    {
                        <div class="sidebar-section sidebar-section-admin">
                            <span class="sidebar-section-title"><i class="fas fa-shield-alt"></i> Admin Panel</span>
                            <a href="/Admin/Dashboard" class="sidebar-link"><i class="fas fa-tachometer-alt"></i> Control Center</a>
                            <a href="/Admin/Users" class="sidebar-link"><i class="fas fa-users"></i> Users</a>
                            <a href="/Admin/Coins" class="sidebar-link"><i class="fas fa-coins"></i> Coin Economy</a>
                            <a href="/Admin/DigitalGoods" class="sidebar-link"><i class="fas fa-cube"></i> Digital Goods</a>
                            <a href="/Admin/SiteAnalytics" class="sidebar-link"><i class="fas fa-chart-line"></i> Analytics</a>
                            <a href="/Admin/PurchaseOrders" class="sidebar-link"><i class="fas fa-credit-card"></i> UPI Orders</a>
                            <a href="/Admin/Promotions" class="sidebar-link"><i class="fas fa-arrow-up"></i> Promotions</a>
                            <a href="/Admin/Logs" class="sidebar-link"><i class="fas fa-list"></i> Logs</a>
                            <a href="/Admin/Settings" class="sidebar-link"><i class="fas fa-cog"></i> Settings</a>
                        </div>
                    }
                    <div class="sidebar-divider"></div>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="sidebar-link sidebar-link-danger">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                }
                else
                {
                    <div class="sidebar-section">
                        <a href="/Account/Login" class="sidebar-link sidebar-link-primary">
                            <i class="fas fa-sign-in-alt"></i> Login with Google
                        </a>
                    </div>
                }
            </nav>
        </div>
    </aside>

    <!-- Right Sidebar -->
    <aside id="right-sidebar" class="sidebar sidebar-right">
        <div class="sidebar-header">
            <h3>Quick Info</h3>
            <button class="sidebar-close" id="right-sidebar-close">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="sidebar-content">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="sidebar-widget">
                    <h4><i class="fas fa-user-circle"></i> Profile</h4>
                    <div class="widget-user">
                        <p class="widget-user-name">@User.Identity.Name</p>
                        <span class="badge badge-primary">@User.FindFirst("UserType")?.Value</span>
                    </div>
                </div>
                <div class="sidebar-widget">
                    <h4><i class="fas fa-coins"></i> Balance</h4>
                    <p class="widget-coin-balance">@ViewBag.UserCoins coins</p>
                    <a href="/Coins/Buy" class="btn btn-warning btn-sm btn-block mt-1">
                        <i class="fas fa-plus"></i> Buy More
                    </a>
                </div>
                <div class="sidebar-widget">
                    <h4><i class="fas fa-bolt"></i> Quick Actions</h4>
                    <div class="widget-actions">
                        <a href="/Marketplace" class="action-btn"><i class="fas fa-store"></i> Market</a>
                        <a href="/Chat" class="action-btn"><i class="fas fa-robot"></i> Chat</a>
                        <a href="/Profile" class="action-btn"><i class="fas fa-user"></i> Profile</a>
                        <a href="/Marketplace/MyPurchases" class="action-btn"><i class="fas fa-shopping-bag"></i> Purchases</a>
                        @if (User.IsInRole("admin") || User.IsInRole("pro"))
                        {
                            <a href="/Marketplace/MyGoods" class="action-btn"><i class="fas fa-cubes"></i> My Goods</a>
                            <a href="/Marketplace/Create" class="action-btn"><i class="fas fa-plus"></i> Create</a>
                        }
                    </div>
                </div>
                <div class="sidebar-widget">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-danger btn-sm btn-block">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="sidebar-widget">
                    <h4>Welcome!</h4>
                    <p class="text-muted">Login to access all features</p>
                    <a href="/Account/Login" class="btn btn-primary btn-block">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                </div>
            }
        </div>
    </aside>

    <!-- Overlay -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="akku-footer">
        <div class="footer-content">
            <p>&copy; 2026 AkkuAppsAi</p>
            <div class="footer-links">
                <a href="/Home/Privacy">Privacy</a>
                <a href="/">Terms</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/ui.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
