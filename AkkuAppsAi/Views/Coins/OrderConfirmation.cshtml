@model AkkuAppsAi.Models.CoinPurchaseOrder
@{ ViewData["Title"] = "Order Confirmation"; }

<div class="page-container" style="max-width:550px;">
    <div class="card animate-scale text-center">
        <div class="card-body">
            <div style="font-size:4rem;color:var(--ok);margin-bottom:1rem;"><i class="fas fa-check-circle"></i></div>
            <h1 style="margin:0;">Order Placed!</h1>
            <p style="color:var(--txt2);">Order ID: <code style="background:var(--bg);padding:2px 8px;border-radius:4px;">@Model.OrderId</code></p>

            <div class="mb-3">
                <div class="setting-item"><span class="setting-label">Coins</span><span class="setting-value coin-amount">@Model.Coins.ToString("N0")</span></div>
                <div class="setting-item"><span class="setting-label">Amount</span><span class="setting-value" style="color:var(--ok);">₹ @Model.AmountINR.ToString("N2")</span></div>
                <div class="setting-item"><span class="setting-label">Status</span><span class="badge badge-warning">Pending Payment</span></div>
            </div>

            <div class="card mb-3" style="background:var(--bg);">
                <div class="card-body text-center">
                    <h3 style="margin:0 0 1rem;"><i class="fas fa-qrcode" style="color:var(--acc)"></i> Pay via UPI</h3>
                    <div style="width:180px;height:180px;margin:0 auto 1rem;background:var(--panel);border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--txt2);">
                        <i class="fas fa-qrcode" style="font-size:3rem;margin-bottom:0.5rem;"></i>
                        <p style="margin:0;font-size:0.8rem;">Admin's GPay QR</p>
                    </div>
                    <p style="color:var(--txt2);font-size:0.85rem;margin-bottom:1rem;">Pay the exact amount and note the Transaction ID from your UPI app.</p>

                    <form method="post" asp-action="SubmitTransactionId">
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <div class="form-group">
                            <label>UPI Transaction ID *</label>
                            <input type="text" name="upiTransactionId" class="form-input" required placeholder="e.g., HDFC123456789" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-paper-plane"></i> Submit Transaction ID</button>
                    </form>
                </div>
            </div>

            <a href="/Coins/MyOrders" class="btn btn-ghost"><i class="fas fa-receipt"></i> View My Orders</a>
        </div>
    </div>
</div>

<style>
    .setting-item { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--bdr); }
    .setting-item:last-child { border-bottom: none; }
    .setting-label { color: var(--txt2); font-size: 0.85rem; }
    .setting-value { font-weight: 600; font-size: 0.9rem; }
</style>
