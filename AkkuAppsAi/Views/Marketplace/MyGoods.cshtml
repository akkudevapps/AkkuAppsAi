@model List<AkkuAppsAi.Models.DigitalGood>
@{ ViewData["Title"] = "My Digital Goods"; }

<div class="page-container">
    <div class="page-header">
        <div>
            <h1><i class="fas fa-cubes"></i> My Digital Goods</h1>
        </div>
        <a href="/Marketplace/Create" class="btn btn-primary"><i class="fas fa-plus"></i> Create New</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-cube"></i>
            <h3>You haven't created any goods yet</h3>
            <a href="/Marketplace/Create" class="btn btn-primary mt-2">Create Your First Good</a>
        </div>
    }
    else
    {
        <div class="grid-3">
            @foreach (var good in Model)
            {
                <div class="card animate-fade">
                    <div style="height:140px;background:var(--bg);">
                        @if (!string.IsNullOrEmpty(good.ThumbnailUrl))
                        { <img src="@good.ThumbnailUrl" alt="@good.Title" style="width:100%;height:100%;object-fit:cover;" /> }
                        else
                        { <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:var(--txt3);"><i class="fas fa-image"></i></div> }
                    </div>
                    <div class="card-body">
                        <h3 style="margin:0 0 0.5rem;font-size:1rem;">@good.Title</h3>
                        <div class="flex justify-between items-center">
                            <span class="coin-amount"><i class="fas fa-coins"></i> @good.PriceInCoins.ToString("N0")</span>
                            <span class="badge @(good.IsActive ? "badge-success" : "badge-danger")">@(good.IsActive ? "Active" : "Inactive")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
