@model AkkuAppsAi.Models.DigitalGood
@{ ViewData["Title"] = Model.Title; }

<div class="page-container">
    <a href="/Marketplace" class="btn btn-ghost btn-sm mb-3"><i class="fas fa-arrow-left"></i> Back to Marketplace</a>

    <div class="grid-2">
        <div class="card">
            <div style="min-height:300px;background:var(--bg);display:flex;align-items:center;justify-content:center;">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                { <img src="@Model.ThumbnailUrl" alt="@Model.Title" style="width:100%;height:100%;object-fit:cover;" /> }
                else
                { <div style="font-size:5rem;color:var(--txt3);"><i class="fas fa-cube"></i></div> }
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Category)) { <span class="badge badge-primary mb-2">@Model.Category</span> }
                <h1 style="margin:0.5rem 0;">@Model.Title</h1>
                <p style="color:var(--txt2);line-height:1.6;margin-bottom:1.5rem;">@Model.Description</p>

                <div class="mb-3">
                    <div class="setting-item"><span class="setting-label">Price</span><span class="setting-value coin-amount"><i class="fas fa-coins"></i> @Model.PriceInCoins.ToString("N0") Coins</span></div>
                    @if (Model.HasCommission)
                    {
                        <div class="setting-item"><span class="setting-label">Commission (10%)</span><span class="setting-value" style="color:var(--err);">@Math.Ceiling(Model.PriceInCoins * 0.1m) Coins</span></div>
                        <div class="setting-item"><span class="setting-label" style="font-weight:600;">Total</span><span class="setting-value coin-amount" style="font-size:1.2rem;">@((Model.PriceInCoins + Math.Ceiling(Model.PriceInCoins * 0.1m)).ToString("N0")) Coins</span></div>
                    }
                    <div class="setting-item"><span class="setting-label">Created</span><span class="setting-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</span></div>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form method="post" asp-action="Buy" asp-controller="Marketplace">
                        <input type="hidden" name="goodId" value="@Model.GoodId" />
                        <button type="submit" class="btn btn-primary btn-lg btn-block">
                            <i class="fas fa-shopping-cart"></i> Buy Now
                            @(Model.HasCommission ? $"({(Model.PriceInCoins + Math.Ceiling(Model.PriceInCoins * 0.1m)).ToString("N0")} coins)" : "")
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-warning btn-lg btn-block"><i class="fas fa-sign-in-alt"></i> Login to Buy</a>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .setting-item { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--bdr); }
    .setting-item:last-child { border-bottom: none; }
    .setting-label { color: var(--txt2); font-size: 0.85rem; }
    .setting-value { font-weight: 600; font-size: 0.9rem; }
    @@media (max-width: 768px) { .grid-2 { grid-template-columns: 1fr; } }
</style>
