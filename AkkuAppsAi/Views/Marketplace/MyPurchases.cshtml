@model List<AkkuAppsAi.Models.Purchase>
@{ ViewData["Title"] = "My Purchases"; }

<div class="page-container">
    <div class="page-header">
        <div>
            <h1><i class="fas fa-receipt"></i> My Purchases</h1>
        </div>
        <a href="/Marketplace" class="btn btn-primary"><i class="fas fa-store"></i> Browse</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-shopping-bag"></i>
            <h3>No purchases yet</h3>
            <a href="/Marketplace" class="btn btn-primary mt-2">Browse Marketplace</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead><tr><th>Good ID</th><th>Coins Paid</th><th>Commission</th><th>Total</th><th>Date</th></tr></thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:0.75rem;">@p.GoodId[..8]</code></td>
                            <td class="coin-amount">@p.CoinsPaid.ToString("N0")</td>
                            <td>@p.AdminCommission.ToString("N0")</td>
                            <td class="coin-amount">@((p.CoinsPaid + p.AdminCommission).ToString("N0"))</td>
                            <td style="font-size:0.8rem;">@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
