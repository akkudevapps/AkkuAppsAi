@model AkkuAppsAi.Models.User
@{ ViewData["Title"] = "My Profile"; }

<div class="page-container">
    <div class="card mb-3 animate-fade">
        <div class="card-body">
            <div class="flex items-center gap-3 flex-wrap">
                @if (!string.IsNullOrEmpty(Model.Avatar))
                { <img src="@Model.Avatar" alt="@Model.Name" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--acc);" /> }
                else
                { <div style="width:80px;height:80px;border-radius:50%;background:var(--acc);color:#fff;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;">@Model.Name[0]</div> }
                <div>
                    <h1 style="margin:0;font-size:1.5rem;">@Model.Name</h1>
                    <p style="color:var(--txt2);margin:0.25rem 0;"><i class="fas fa-envelope"></i> @Model.Email</p>
                    <div class="flex gap-1 flex-wrap mt-1">
                        <span class="badge @(Model.UserType == "AkkuAdmin" ? "badge-danger" : Model.UserType == "AkkuProUser" ? "badge-purple" : "badge-primary")">@Model.UserType</span>
                        <span class="badge badge-primary">@Model.Role</span>
                        @if (Model.IsVerified) { <span class="badge badge-success"><i class="fas fa-check"></i> Verified</span> }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="stats-grid mb-3">
        <div class="stat-card gold animate-fade">
            <div class="stat-icon"><i class="fas fa-coins"></i></div>
            <div class="stat-info"><h3>@Model.CoinBalance.ToString("N0")</h3><p>Coins</p></div>
        </div>
        <div class="stat-card glow-blue animate-fade">
            <div class="stat-icon"><i class="fas fa-wallet"></i></div>
            <div class="stat-info"><h3>@Model.WalletBalance.ToString("N2")</h3><p>Wallet</p></div>
        </div>
        <div class="stat-card glow-green animate-fade">
            <div class="stat-icon"><i class="fas fa-calendar"></i></div>
            <div class="stat-info"><h3>@Model.CreatedAt.ToString("MMM yyyy")</h3><p>Joined</p></div>
        </div>
    </div>

    <div class="card mb-3 animate-fade">
        <div class="card-header"><h3 style="margin:0;font-size:1rem;"><i class="fas fa-edit" style="color:var(--acc)"></i> Bio</h3></div>
        <div class="card-body">
            <form method="post" asp-action="UpdateBio">
                <textarea name="bio" class="form-input" rows="2" placeholder="Tell us about yourself...">@Model.Bio</textarea>
                <button type="submit" class="btn btn-primary btn-sm mt-1"><i class="fas fa-save"></i> Save</button>
            </form>
        </div>
    </div>

    <div class="card animate-fade">
        <div class="card-header">
            <div class="flex gap-1">
                <button class="btn btn-sm btn-primary tab-btn" data-tab="transactions">Transactions</button>
                <button class="btn btn-sm btn-ghost tab-btn" data-tab="purchases">Purchases</button>
            </div>
        </div>
        <div class="card-body" style="padding:0;">
            <div id="tab-transactions" class="tab-content active">
                <div class="table-wrap" style="border:none;border-radius:0;">
                    <table>
                        <thead><tr><th>Type</th><th>Amount</th><th>Balance</th><th>Description</th><th>Date</th></tr></thead>
                        <tbody>
                            @foreach (var t in (ViewBag.Transactions as List<AkkuAppsAi.Models.CoinTransaction>) ?? new())
                            {
                                <tr>
                                    <td><span class="badge badge-primary">@t.ReferenceType</span></td>
                                    <td class="@(t.Amount >= 0 ? "amount-pos" : "amount-neg")">@t.Amount.ToString("N0")</td>
                                    <td class="coin-amount">@t.BalanceAfter.ToString("N0")</td>
                                    <td style="font-size:0.85rem;color:var(--txt2);">@t.Description</td>
                                    <td style="font-size:0.8rem;">@t.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div id="tab-purchases" class="tab-content" style="display:none;">
                <div class="table-wrap" style="border:none;border-radius:0;">
                    <table>
                        <thead><tr><th>Good ID</th><th>Coins</th><th>Commission</th><th>Total</th><th>Date</th></tr></thead>
                        <tbody>
                            @foreach (var p in (ViewBag.Purchases as List<AkkuAppsAi.Models.Purchase>) ?? new())
                            {
                                <tr>
                                    <td><code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:0.75rem;">@p.GoodId[..8]</code></td>
                                    <td class="coin-amount">@p.CoinsPaid.ToString("N0")</td>
                                    <td>@p.AdminCommission.ToString("N0")</td>
                                    <td class="coin-amount">@((p.CoinsPaid + p.AdminCommission).ToString("N0"))</td>
                                    <td style="font-size:0.8rem;">@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('btn-primary'); b.classList.add('btn-ghost'); });
            document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
            this.classList.remove('btn-ghost'); this.classList.add('btn-primary');
            document.getElementById('tab-' + this.dataset.tab).style.display = 'block';
        });
    });
</script>
